PORT=3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/turnos?retryWrites=true&w=majority

# JWT — generá una clave larga y aleatoria
JWT_SECRET=una_clave_secreta_muy_larga_y_aleatoria_cambiar_esto

# Twilio (cada tenant configura el suyo desde la app)
# Estos son los valores de fallback si no están en DB
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Cron secret (Vercel lo envía automáticamente si lo configurás como env var)
CRON_SECRET=otra_clave_secreta_larga
