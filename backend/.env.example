# Puerto local (no se usa en Vercel)
PORT=3001

# MongoDB Atlas — obtené la URI en https://cloud.mongodb.com
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/turnos?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/turnos?retryWrites=true&w=majority

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Seguridad del endpoint de cron (Vercel lo envía automáticamente)
CRON_SECRET=una_clave_secreta_larga
